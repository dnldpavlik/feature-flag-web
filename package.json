{
  "name": "feature-flags-web",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "//-- Development --//": "",
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4200",
    "watch": "ng build --watch --configuration development",
    "//-- Build --//": "",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "//-- Unit Testing (Jest) --//": "",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "//-- E2E Testing (Playwright) --//": "",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test --project=smoke",
    "e2e:journeys": "playwright test --project=journeys",
    "e2e:regression": "playwright test --project=regression",
    "e2e:all-browsers": "playwright test --project=regression --project=firefox --project=webkit",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "//-- Code Quality --//": "",
    "lint": "npm run lint:ts && npm run lint:scss",
    "lint:ts": "eslint \"src/**/*.{ts,html}\"",
    "lint:scss": "stylelint \"src/**/*.scss\"",
    "lint:fix": "eslint src --ext .ts,.html --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\"",
    "typecheck": "tsc --noEmit",
    "//-- CI/CD --//": "",
    "ci:local": "npm run lint && npm run test:coverage && npm run build",
    "e2e:ci": "E2E_ENV=staging playwright test --project=smoke --project=journeys",
    "//-- Dependency Management --//": "",
    "check-updates": "npm outdated",
    "check-updates:major": "npx npm-check-updates",
    "update-deps": "npx npm-check-updates -u && npm install",
    "update-deps:minor": "npx npm-check-updates -u --target minor && npm install",
    "update-deps:patch": "npx npm-check-updates -u --target patch && npm install",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "//-- Hooks --//": "",
    "prepare": "husky"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.html": [
      "eslint --fix",
      "prettier --write --parser angular"
    ],
    "*.scss": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.2",
    "@angular/common": "^21.1.2",
    "@angular/compiler": "^21.1.2",
    "@angular/core": "^21.1.2",
    "@angular/forms": "^21.1.2",
    "@angular/platform-browser": "^21.1.2",
    "@angular/router": "^21.1.2",
    "keycloak-angular": "^21.0.0",
    "keycloak-js": "^26.2.3",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.2.0",
    "@angular-eslint/eslint-plugin": "^21.2.0",
    "@angular-eslint/eslint-plugin-template": "^21.2.0",
    "@angular-eslint/schematics": "^21.2.0",
    "@angular-eslint/template-parser": "^21.2.0",
    "@angular/build": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.2",
    "@angular/platform-browser-dynamic": "^21.1.2",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.0",
    "@testing-library/angular": "^19.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "angular-eslint": "^21.2.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-junit": "^16.0.0",
    "jest-preset-angular": "^16.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "stylelint": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
