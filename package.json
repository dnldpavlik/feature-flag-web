{
  "name": "feature-flags-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4200",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "lint": "npm run lint:ts && npm run lint:scss",
    "lint:ts": "eslint \"src/**/*.{ts,html}\"",
    "lint:scss": "stylelint \"src/**/*.scss\"",
    "lint:fix": "eslint src --ext .ts,.html --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\"",
    "typecheck": "tsc --noEmit",
    "ci:local": "npm ci && npm run lint && npm run test:coverage && npm run build",
    "check-updates": "npm outdated",
    "check-updates:major": "ncu",
    "update-deps": "ncu -u && npm install",
    "update-deps:minor": "ncu -u --target minor && npm install",
    "update-deps:patch": "ncu -u --target patch && npm install",
    "audit": "npm audit",
    "audit:fix": "npm audit fix"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.0",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^19.5.0",
    "@angular-eslint/eslint-plugin": "^19.5.0",
    "@angular-eslint/eslint-plugin-template": "^19.5.0",
    "@angular-eslint/schematics": "^19.5.0",
    "@angular-eslint/template-parser": "^19.5.0",
    "@angular/build": "^20.3.6",
    "@angular/cli": "^20.3.6",
    "@angular/compiler-cli": "^20.3.0",
    "@playwright/test": "^1.50.0",
    "@testing-library/angular": "^17.3.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.0",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.4.0",
    "prettier": "^3.4.0",
    "typescript": "~5.9.2"
  }
}
