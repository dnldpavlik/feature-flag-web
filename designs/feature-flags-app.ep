<?xml version="1.0" encoding="UTF-8"?>
<Document xmlns="http://www.evolus.vn/Namespace/Pencil" version="1.4">
  <Properties>
    <Property name="documentTitle">Feature Flags Application - Desktop Designs</Property>
    <Property name="author">Claude Code</Property>
    <Property name="description">Desktop UI designs for Feature Flag management system (LaunchDarkly clone)</Property>
    <Property name="width">1440</Property>
    <Property name="height">900</Property>
    <Property name="backgroundColor">#FFFCF5</Property>
  </Properties>

  <!-- Page 1: Dashboard -->
  <Page name="1. Dashboard" id="dashboard_page" width="1440" height="900">
    <Properties>
      <Property name="fid">dashboard_page</Property>
      <Property name="name">1. Dashboard</Property>
      <Property name="description">Main dashboard showing overview and recent flags</Property>
    </Properties>
    <Content>
      <!-- Sidebar -->
      <Shape id="sidebar_bg" type="Rectangle" x="0" y="0" width="240" height="900">
        <p:fillColor>#FAF7F0</p:fillColor>
        <p:strokeColor>#E8E5E0</p:strokeColor>
        <p:strokeWidth>1</p:strokeWidth>
      </Shape>

      <!-- Logo and Title -->
      <Shape id="logo_icon" type="RoundedRect" x="16" y="16" width="32" height="32">
        <p:fillColor>#8E3D03</p:fillColor>
        <p:cornerRadius>6</p:cornerRadius>
      </Shape>
      <Shape id="app_title" type="PlainText" x="56" y="16" width="168" height="32">
        <p:textContent>Feature Flags</p:textContent>
        <p:fontFamily>Arial</p:fontFamily>
        <p:fontSize>18</p:fontSize>
        <p:fontWeight>bold</p:fontWeight>
        <p:textColor>#040403</p:textColor>
      </Shape>

      <Shape id="sidebar_divider1" type="Line" x="0" y="64" width="240" height="1">
        <p:strokeColor>#E8E5E0</p:strokeColor>
      </Shape>

      <!-- Navigation Items -->
      <Shape id="nav_dashboard" type="RoundedRect" x="12" y="76" width="216" height="36">
        <p:fillColor>#E8E5E0</p:fillColor>
        <p:cornerRadius>4</p:cornerRadius>
      </Shape>
      <Shape id="nav_dashboard_icon" type="RoundedRect" x="20" y="84" width="20" height="20">
        <p:fillColor>#8E3D03</p:fillColor>
        <p:cornerRadius>2</p:cornerRadius>
      </Shape>
      <Shape id="nav_dashboard_text" type="PlainText" x="48" y="82" width="168" height="24">
        <p:textContent>Dashboard</p:textContent>
        <p:fontFamily>Arial</p:fontFamily>
        <p:fontSize>14</p:fontSize>
        <p:textColor>#040403</p:textColor>
      </Shape>

      <Shape id="nav_flags" type="RoundedRect" x="12" y="120" width="216" height="36">
        <p:fillColor>transparent</p:fillColor>
      </Shape>
      <Shape id="nav_flags_icon" type="RoundedRect" x="20" y="128" width="20" height="20">
        <p:fillColor>#535955</p:fillColor>
        <p:cornerRadius>2</p:cornerRadius>
      </Shape>
      <Shape id="nav_flags_text" type="PlainText" x="48" y="126" width="168" height="24">
        <p:textContent>Feature Flags</p:textContent>
        <p:fontFamily>Arial</p:fontFamily>
        <p:fontSize>14</p:fontSize>
        <p:textColor>#262725</p:textColor>
