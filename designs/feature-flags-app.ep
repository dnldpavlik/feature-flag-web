      <Shape id="env_staging_dot" type="Ellipse" x="20" y="466" width="8" height="8">
        <p:fillColor>#EAB308</p:fillColor>
      </Shape>
      <Shape id="env_staging_text" type="PlainText" x="36" y="462" width="188" height="20">
        <p:textContent>Staging</p:textContent>
        <p:fontFamily>Arial</p:fontFamily>
        <p:fontSize>13</p:fontSize>
        <p:textColor>#262725</p:textColor>
      </Shape>

      <Shape id="env_prod_dot" type="Ellipse" x="20" y="494" width="8" height="8">
