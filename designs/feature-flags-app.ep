      <!-- User Menu Footer -->
      <Shape id="sidebar_divider2" type="Line" x="0" y="836" width="240" height="1">
        <p:strokeColor>#E8E5E0</p:strokeColor>
      </Shape>
      <Shape id="user_name" type="PlainText" x="16" y="852" width="208" height="20">
