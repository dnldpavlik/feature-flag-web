# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
max_line_length = off
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{json,json5}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{scss,css}]
indent_size = 2

[*.{ts,tsx,js,jsx}]
indent_size = 2
max_line_length = 100
